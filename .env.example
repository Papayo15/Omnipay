# ==========================================
# OMNIPAY PROTOCOL — Variables de Entorno
# ==========================================
# Copia como .env.local y completa los valores.
# NUNCA subas .env.local a Git.

# ══════════════════════════════════════════
# FASE 1 — ACTIVOS (obtener ahora, sin empresa)
# ══════════════════════════════════════════

# Wise — RIEL RETIRADO — ya no se utiliza en este sistema
# Reemplazado por: Stripe (Occidente + LATAM), Airwallex (Asia), Binance Pay (restringidos)

# ── Flutterwave — África (NG, GH, KE, TZ, UG, ZA, SN, CI, CM, RW, ET, EG) ──
# Registro: dashboard.flutterwave.com → individuo → API Keys
FLW_SECRET_KEY=              # empieza con FLWSECK_TEST_ (sandbox) o FLWSECK_ (prod)

# Airwallex — Riel Asia Oriental
# Obtener: portal.airwallex.com → Settings → API Keys
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=

# Stripe — Fallback tarjeta crédito/débito
# Obtener: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=

# Stablecoin Bridge — Binance Pay (VE, NG, PK, EG, TR, GH, RU, KE, UG, TZ)
# Persona física en México — fuera de jurisdicción OFAC directa
# Obtener: bpay.binance.com → Merchant Center → API Management
BINANCE_PAY_API_KEY=           # Certificate SN (identificador del merchant)
BINANCE_PAY_SECRET_KEY=        # Secret key para HMAC-SHA512

# OmniPay Corporativo (destino de comisiones 0.25%)
OMNIPAY_CORPORATE_ACCOUNT_TOKEN=

# Seguridad — clave HMAC para firmar payloads
# Genera con: openssl rand -base64 32
OMNIPAY_HMAC_SECRET=

# Geofencing / OFAC — IPInfo (gratis hasta 50k req/mes)
# Obtener: ipinfo.io → Dashboard → Token
NEXT_PUBLIC_IPINFO_TOKEN=

# URL pública de la app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Twilio (SMS + WhatsApp) ──
# Registro instantáneo: twilio.com → Sign Up → Get a free number
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=              # número en E.164: +15551234567

# WhatsApp via Twilio
# Sandbox GRATIS: usa +14155238886 durante desarrollo (no necesita aprobación Meta)
TWILIO_WHATSAPP_SANDBOX=true      # true = sandbox gratis, false = producción
TWILIO_WHATSAPP_NUMBER=           # solo si SANDBOX=false (requiere aprobación Meta ~7 días)

# ── Webhook secrets (los dashboards los generan automáticamente) ──
# WISE_WEBHOOK_SECRET= (retirado)
AIRWALLEX_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET=            # empieza con whsec_...

# ── Mercuryo (Fase 3 — Rusia/P2P cripto) ──
# Nota: Rusia está bloqueada por OFAC en Fase 1. Este riel está reservado.
# MERCURYO_API_KEY=
# MERCURYO_WEBHOOK_SECRET=

# ══════════════════════════════════════════
# FASE 2 — RESERVADOS (requieren cuenta corporativa)
# ══════════════════════════════════════════

# Open Banking LATAM (Belvo) — belvo.com → empresa registrada
# BELVO_SECRET_ID=
# BELVO_SECRET_PASSWORD=
# BELVO_ENV=sandbox

# Open Banking USA/CA (Plaid) — plaid.com → empresa + revisión legal
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox

# Open Banking Europa (Tink) — tink.com → empresa registrada en EU
# TINK_CLIENT_ID=
# TINK_CLIENT_SECRET=
# TINK_ACCESS_TOKEN=

# China (Alipay+ / Ant International) — cuenta merchant china
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=

# Rusia SBP — bloqueado Fase 1 por precaución OFAC
# SBP_BRIDGE_API_KEY=
# SBP_BRIDGE_ENDPOINT=

# LATAM sin Open Banking (dLocalGo) — empresa registrada
# DLOCALGO_API_KEY=
# DLOCALGO_SECRET_KEY=
# DLOCALGO_ENV=sandbox
