# ══════════════════════════════════════════════════════════════════
#  OmniPay — Variables de Entorno (Arquitectura Canadá Hub)
#  Copia como .env.local y completa los valores.
#  NUNCA subas .env.local a Git.
# ══════════════════════════════════════════════════════════════════

# ── STRIPE CANADÁ (procesamiento de entrada global) ───────────────
# Live Mode · Sole Proprietorship · Statement Descriptor: OMNIPAY
# Obtener: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── WISE CANADÁ (riel de respaldo + receptor de comisiones) ───────
# Balances en CAD (Transit / Institution / Account) y USD
# Obtener: wise.com/gb/business/api
WISE_API_TOKEN=...
WISE_PROFILE_ID=...

# ── TWILIO (SMS automático cifrado tras cada pago exitoso) ────────
# Registro: twilio.com → número en E.164: +1XXXXXXXXXX
TWILIO_ACCOUNT_SID=...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ── RUTAS ESPECIALES (preparadas · no activas por defecto) ────────
# Binance Pay — transacciones alternativas (Rusia / mercados restringidos)
# Obtener: bpay.binance.com → Merchant Center → API Management
BINANCE_PAY_API_KEY=...
BINANCE_PAY_SECRET_KEY=...

# Airwallex — procesamiento Asia / Alipay
# Obtener: portal.airwallex.com → Settings → API Keys
AIRWALLEX_CLIENT_ID=...
AIRWALLEX_API_KEY=...

# ── SEGURIDAD ─────────────────────────────────────────────────────
# LINK_SECRET: firma HMAC-SHA256 de links de pago dinámicos (5 min)
# Genera con: openssl rand -base64 48
LINK_SECRET=...

# Firma interna de payloads del sistema
OMNIPAY_HMAC_SECRET=...

# ── APP ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://omnipay.app
NEXT_PUBLIC_IPINFO_TOKEN=
