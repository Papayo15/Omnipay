# ══════════════════════════════════════════════════════════════════
#  OmniPay — Variables de Entorno (Orquestador Stateless)
#  Copia como .env.local y completa los valores.
#  NUNCA subas .env.local a Git.
# ══════════════════════════════════════════════════════════════════

# ── STRIPE CONNECT (Flujo COBRO — Clip Killer) ────────────────────
# El dinero va directo de la tarjeta del cliente a la cuenta del comercio.
# OmniPay toma 1% via application_fee — nunca toca los fondos.
# Obtener: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── AIRWALLEX (Flujo REMESA — USA / Europa / LATAM) ───────────────
# Obtener: portal.airwallex.com → Settings → API Keys
AIRWALLEX_CLIENT_ID=...
AIRWALLEX_API_KEY=...

# ── THUNES (Flujo REMESA — Asia / China / África) ─────────────────
# Proveedor con licencias MSB en 130+ países. wallets móviles + banco.
# Obtener: thunes.com → Partners → API Access
THUNES_CLIENT_ID=...
THUNES_SECRET=...

# ── BRIDGE.XYZ (Flujo REMESA — Rusia / stablecoin) ────────────────
# Para mercados con restricciones de divisas. Stablecoin bridge.
# Obtener: bridge.xyz → Dashboard → API Keys
BRIDGE_API_KEY=...

# ── TWILIO (SMS comprobante a comercio y cliente) ─────────────────
# Registro: twilio.com → número en E.164: +1XXXXXXXXXX
TWILIO_ACCOUNT_SID=...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ── SEGURIDAD ─────────────────────────────────────────────────────
# LINK_SECRET: firma HMAC-SHA256 de links de pago (TTL 5 min estricto)
# Genera con: openssl rand -base64 48
LINK_SECRET=...

# ── WISE (dispersión a cuentas bancarias) ────────────────────────
# Obtener: wise.com/business → Settings → API Tokens
# WISE_PROFILE_ID: curl https://api.wise.com/v1/profiles -H "Authorization: Bearer $WISE_API_KEY" → type:"business" → id
WISE_API_KEY=...
WISE_PROFILE_ID=...
WISE_WEBHOOK_PUBLIC_KEY=...   # PEM público de Wise para verificar webhooks

# ── PAYSEND (push a tarjetas Visa/MC) ────────────────────────────
PAYSEND_API_KEY=...

# ── NIUM (fallback card + wallet — 190 países) ───────────────────
NIUM_API_KEY=...
NIUM_CLIENT_HASH_ID=...

# ── ADMIN ─────────────────────────────────────────────────────────
ADMIN_SECRET=...   # acceso a /api/admin/stats

# ── APP ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://omnipay.app
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
NEXT_PUBLIC_IPINFO_TOKEN=   # OFAC geofencing (opcional, ipinfo.io)

# ── PAYOUT MODE (liquidez OmniPay) ───────────────────────────────
# STANDARD: Stripe deposita en 1-2 días hábiles (sin costo extra)
# INSTANT:  Stripe Instant Payout a tarjeta Visa Wise (~10 min, +1% fee)
#           → activa cuando el float Wise está bajo para acelerar la reposición
NEXT_PUBLIC_PAYOUT_MODE=STANDARD
